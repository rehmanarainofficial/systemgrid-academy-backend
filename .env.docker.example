DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=systemgrid
DATABASE_USERNAME=systemgrid
DATABASE_PASSWORD=systemgrid_dev_password
DATABASE_NAME=systemgrid_academy
DATABASE_SYNCHRONIZE=false

NODE_ENV=production
PORT=5000
API_PREFIX=api/v1
FRONTEND_URL=https://academy.thesystemgrid.com
TRUST_PROXY=true
LOG_LEVEL=log
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

JWT_ACCESS_SECRET=replace-with-a-long-production-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-production-refresh-secret
JWT_RESET_SECRET=replace-with-a-long-production-reset-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m
UPLOAD_DIR=uploads
BACKEND_PUBLIC_URL=https://api-academy.thesystemgrid.com
STORAGE_DRIVER=s3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=replace-with-your-bucket-name
AWS_S3_PUBLIC_BASE_URL=https://replace-with-your-cloudfront-or-public-s3-domain
# Prefer an EC2/ECS IAM role. Use rotated environment credentials only when a role is unavailable.
AWS_ACCESS_KEY_ID=replace-with-a-rotated-access-key
AWS_SECRET_ACCESS_KEY=replace-with-a-rotated-secret-key

PGADMIN_DEFAULT_EMAIL=admin@systemgrid.academy
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050
