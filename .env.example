NODE_ENV=development
PORT=5000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000
TRUST_PROXY=false
LOG_LEVEL=log
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=systemgrid
DATABASE_USERNAME=systemgrid
DATABASE_PASSWORD=systemgrid_dev_password
DATABASE_NAME=systemgrid_academy
DATABASE_SYNCHRONIZE=false

JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_RESET_SECRET=replace-with-a-long-reset-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m
COOKIE_DOMAIN=localhost

UPLOAD_DIR=uploads
BACKEND_PUBLIC_URL=http://localhost:5000
STORAGE_DRIVER=local

AWS_REGION=ap-south-1
AWS_S3_BUCKET=replace-with-your-bucket-name
AWS_S3_PUBLIC_BASE_URL=https://replace-with-your-public-s3-or-cloudfront-domain
AWS_ACCESS_KEY_ID=replace-with-a-rotated-access-key
AWS_SECRET_ACCESS_KEY=replace-with-a-rotated-secret-key

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=academy@thesystemgrid.com
MAIL_PASS=replace-with-mail-password
MAIL_FROM_NAME=SystemGrid Academy
MAIL_FROM_EMAIL=academy@thesystemgrid.com
MAIL_SECURE=false

JAZZCASH_MERCHANT_ID=replace-with-jazzcash-merchant-id
JAZZCASH_PASSWORD=replace-with-jazzcash-password
JAZZCASH_INTEGRITY_SALT=replace-with-jazzcash-integrity-salt
JAZZCASH_RETURN_URL=http://localhost:3000/payment/pending
JAZZCASH_CALLBACK_URL=http://localhost:5000/api/v1/payments/callback/jazzcash
JAZZCASH_ENV=sandbox

EASYPAISA_STORE_ID=replace-with-easypaisa-store-id
EASYPAISA_HASH_KEY=replace-with-easypaisa-hash-key
EASYPAISA_USERNAME=replace-with-easypaisa-username
EASYPAISA_PASSWORD=replace-with-easypaisa-password
EASYPAISA_RETURN_URL=http://localhost:3000/payment/pending
EASYPAISA_CALLBACK_URL=http://localhost:5000/api/v1/payments/callback/easypaisa
EASYPAISA_ENV=sandbox

SEED_ADMIN_NAME=SystemGrid Super Admin
SEED_ADMIN_EMAIL=admin@systemgrid.academy
SEED_ADMIN_PASSWORD=ChangeMe123!
